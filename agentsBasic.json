            "description": "Shell commands",
            "context": {
                "file": "shellSystemPrompt.txt"
            },
            "mcpServers": [
                "shell"
            ]
        },
        {
            "name": "SQLite",
            "id": "sqlite",
            "description": "SQLite Integration",
            "context": {
                "file": "sqliteContext.txt"
            },
            "hitlConfig" :{
                "targets" : [
                    {
                        "type" : "webhook",
                        "instance" : "http://localhost:8090/hil"
